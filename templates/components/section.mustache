{{!
    @template format_ludilearn/components/course
}}
{{#js}}
    require([
    'format_ludilearn/local/reactive',
    'format_ludilearn/local/{{type}}/section',
    ], function(reactive, component) {

        // Initialize state before component init.
        const jsonstate = {{{jsonstate}}};
        const stateManager = reactive.ludilearn.getStateManager();
        stateManager.setReadOnly(false);
        stateManager.processUpdates(jsonstate);
        stateManager.setReadOnly(true);

        // Data to pass to the component.
        const data = {
            sectionid: {{id}}
        };
        component.init('ludilearn-{{type}}-section', reactive.ludilearn, data);
    });
{{/js}}